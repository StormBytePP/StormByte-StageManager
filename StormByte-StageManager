	# If we provided a parameter then it means we come here by a rebase not a normal use, so we adapt message reflecting this fact
	if [ "$#" -eq 0 ]; then
		text="Extracting system files from ${tarball}"
	else
		text="Rebasing `basename $1` using system files from ${tarball}"
	fi
	cd "${tmp_folder}"
	handleCommandWithOutput "pv ${tarball_filename_fullpath} | ${extract} | ${tar_decompress}" "${text}"
}

##
# @brief Saves changes made in the chroot environment back to the tarball.
#
# @param [optional] $1 The new tarball file name (used for rebasing).
##
function saveChanges() {
	local reply=""
	while [[ ! $reply =~ ^[YyNn]$ ]]; do
		printf "  ${_CLR_BOLD_WHITE}Save changes?${_CLR_RESET} [${_CLR_BOLD_GREEN}Y${_CLR_RESET}/${_CLR_BOLD_RED}N${_CLR_RESET}]: "
		read -r
		reply=$REPLY
	done
	if [[ $reply =~ ^[Yy]$ ]]; then
		if [ "${USE_CCACHE_FILE}" == "YES" ] || [ "${USE_SCCACHE_FILE}" == "YES" ]; then
			saveCache
		fi
		# Stop sccache server before cleaning caches to avoid race conditions
		stopSccacheServer
		cleanCaches
		# If we came from a rebase request, then we need to temporary set file and revert back for cleaning purposes
		if [ "$#" -ne 0 ]; then
			setAndCheckFile "${TARBALL_FOLDER}/${parameters[2]}"
		fi
		# Set readonly so nothing is injected while compressing
		readonlyTEMP
		compressArchive
		if [ "$#" -ne 0 ]; then
			setAndCheckFile
		fi
	else
		# If content was not saved, stop any sccache server and set readonly so it can be unmounted safely
		stopSccacheServer
		readonlyTEMP
		printf "  ${_CLR_DIM}No changes saved.${_CLR_RESET}\n"
	fi
}

##
# @brief Compresses the chroot environment into a tarball.
##
function compressArchive() {
	cd "${tmp_folder}"
	handleCommandWithOutput "${tar_compress} | pv -s $(du -sbl ${tmp_folder} | awk '{print $1}') | ${compress} > ${output_folder}/.${tarball_output}.compress" "Compressing system files to ${tarball_output}"
	mv "${output_folder}/.${tarball_output}.compress" "${output_folder}/${tarball_output}"
}

##
# @brief Extracts the ccache data into the chroot environment.
##
function unpackCache() {
	if [ "${USE_CCACHE}" == "YES" ] && [ "${USE_CCACHE_FILE}" == "YES" ]; then
		if [ -f "${ccache_file}" ]; then
			local prev_folder=`pwd`
			cd "${tmp_folder}${CCACHE_DIR}"
			handleCommandWithOutput "pv ${ccache_file} | ${bzip2} -d - | ${tar_decompress}" "Extracting CCache data..."
			cd "${prev_folder}"
			# Use chown from inside the chroot to resolve 'portage' to chroot's UID/GID
			chroot "${tmp_folder}" chown -R portage:portage "${CCACHE_DIR}"
			chmod -R 770 "${tmp_folder}${CCACHE_DIR}"
		fi
	fi
	if [ "${USE_SCCACHE}" == "YES" ] && [ "${USE_SCCACHE_FILE}" == "YES" ]; then
		if [ -f "${sccache_file}" ]; then
			local prev_folder=`pwd`
			cd "${tmp_folder}${SCCACHE_DIR}"
			handleCommandWithOutput "pv ${sccache_file} | ${bzip2} -d - | ${tar_decompress}" "Extracting Sccache data..."
			cd "${prev_folder}"
			# Use chown from inside the chroot to resolve 'portage' to chroot's UID/GID
			chroot "${tmp_folder}" chown -R portage:portage "${SCCACHE_DIR}"
			chmod -R 770 "${tmp_folder}${SCCACHE_DIR}"
		fi
	fi
}

##
# @brief Compresses and saves the ccache data from the chroot environment.
##
function saveCache() {
	if [ "${USE_CCACHE}" == "YES" ] && [ "${USE_CCACHE_FILE}" == "YES" ]; then
		local prev_folder=`pwd`
		cd "${tmp_folder}${CCACHE_DIR}"
		handleCommandWithOutput "${tar_compress} | pv -s $(du -sbl . | awk '{print $1}') | ${bzip2} > ${ccache_file}" "Compressing CCache data"
		printStep "Cleaning CCache contents after save"
		rm -Rf "${tmp_folder}${CCACHE_DIR}/"* > /dev/null 2>&1
		if [ $? -ne 0 ]; then
			printFail
			cd "${current_folder}"
			displayError "ERROR cleaning CCache contents in ${tmp_folder}"
		fi
		printOK
		cd "${prev_folder}"
	fi
	if [ "${USE_SCCACHE}" == "YES" ] && [ "${USE_SCCACHE_FILE}" == "YES" ]; then
		local prev_folder=`pwd`
		cd "${tmp_folder}${SCCACHE_DIR}"
		handleCommandWithOutput "${tar_compress} | pv -s $(du -sbl . | awk '{print $1}') | ${bzip2} > ${sccache_file}" "Compressing Sccache data"
		printStep "Cleaning Sccache contents after save"
		rm -Rf "${tmp_folder}${SCCACHE_DIR}/"* > /dev/null 2>&1
		if [ $? -ne 0 ]; then
			printFail
			cd "${current_folder}"
			displayError "ERROR cleaning Sccache contents in ${tmp_folder}"
		fi
		printOK
		cd "${prev_folder}"
	fi
}

##
# @brief Enters the chroot environment.
