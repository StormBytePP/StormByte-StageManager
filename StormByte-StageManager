##
# @brief Validates that a path variable is safe for use in shell operations.
#
# Rejects paths that are not absolute, contain path traversal sequences (..),
# or contain shell metacharacters. This prevents injection attacks when config
# variables are used in shell commands.
#
# @param $1 The variable name (for error messages).
# @param $2 The path value to validate.
# @return 0 if safe, 1 if unsafe.
##
function validateSafePath() {
	local var_name="$1"
	local var_value="$2"
	# Must be an absolute path
	if [[ "${var_value}" != /* ]]; then
		echo "${_CLR_RED}  ✗${_CLR_RESET} ${var_name} must be an absolute path: ${var_value}"
		return 1
	fi
	# Whitelist: only alphanumeric characters, /, -, _, and . are allowed.
	# This prevents shell metacharacters from being injected into commands.
	if [[ "${var_value}" =~ [^a-zA-Z0-9/_.-] ]]; then
		echo "${_CLR_RED}  ✗${_CLR_RESET} ${var_name} contains unsafe characters (only alphanumeric, /, -, _, . are allowed): ${var_value}"
		return 1
	fi
	# Reject path traversal sequences (..) by checking each component
	local saved_ifs="${IFS}"
	IFS='/' read -ra path_parts <<< "${var_value}"
	IFS="${saved_ifs}"
	local part
	for part in "${path_parts[@]}"; do
		if [ "${part}" = ".." ]; then
			echo "${_CLR_RED}  ✗${_CLR_RESET} ${var_name} contains path traversal sequence (..): ${var_value}"
			return 1
		fi
	done
	return 0
}

##
# @brief Validates configuration variables.
#
# Checks the validity of configuration variables such as storage system, compression levels,
# and directory paths. Exits with an error if any validation fails.
##
function checkVars() {
	local errors=0
	if [ -z "${STORAGE_SYSTEM}" ] || [ "${STORAGE_SYSTEM}" != "zram" ] && [ "${STORAGE_SYSTEM}" != "tmpfs" ] && [ "${STORAGE_SYSTEM}" != "folder" ]; then
		echo "${_CLR_RED}  ✗${_CLR_RESET} STORAGE_SYSTEM variable is not set, is empty or contains an invalid value!"
		errors=1
	fi
	# We only check for STORAGE_SIZE if zram or tmpfs is set to be used
	if [ "${STORAGE_SYSTEM}" = "zram" ] || [ "${STORAGE_SYSTEM}" = "tmpfs" ]; then
		local re="^[1-9][0-9]*[MG]$" # For checking storage size (non-zero)
		if ! [[ "${STORAGE_SIZE}" =~ $re ]]; then
			echo "${_CLR_RED}  ✗${_CLR_RESET} STORAGE_SIZE is either empty, zero, or invalid, check if its value is correct!"
			errors=1
		fi
	fi
	if [ "${STORAGE_SYSTEM}" = "zram" ]; then
		if ! [ -z "${STORAGE_SYSTEM_ZRAM_COMPRESSION_ALGO}" ]; then
			case "${STORAGE_SYSTEM_ZRAM_COMPRESSION_ALGO}" in
				zstd|lz4|lz4hc)
					# Valid algorithm → do nothing
					;;
				*)
					echo "${_CLR_RED}  ✗${_CLR_RESET} STORAGE_SYSTEM_ZRAM_COMPRESSION_ALGO='${STORAGE_SYSTEM_ZRAM_COMPRESSION_ALGO}' is invalid." >&2
					echo "   Available values are: zstd, lz4, lz4hc" >&2
					errors=1
					;;
			esac
		fi
	fi

	if [ -z "${TARBALL_FOLDER}" ]; then
		echo "${_CLR_RED}  ✗${_CLR_RESET} TARBALL_FOLDER variable is not set or empty!"
		errors=1
	elif ! validateSafePath "TARBALL_FOLDER" "${TARBALL_FOLDER}"; then
		errors=1
	fi
	if [ ! -f "${TARBALL_NOTE_EDITOR}" ]; then
		echo "${_CLR_RED}  ✗${_CLR_RESET} Editor executable is not found"
		errors=1
	fi
	if [ "${DETACH_NOTE_EDITOR}" != "NO" ] && [ "${DETACH_NOTE_EDITOR}" != "YES" ]; then
		echo "${_CLR_RED}  ✗${_CLR_RESET} DETACH_NOTE_EDITOR variable only accepts values YES and NO"
		errors=1
	fi
	if ! [[ "${GZIP_COMPRESSION_LEVEL}" =~ ^[1-9]$ ]]; then
		echo "${_CLR_RED}  ✗${_CLR_RESET} Gzip compression level is not in a range between 1 and 9!"
		errors=1
	fi
	if ! [[ "${BZIP_COMPRESSION_LEVEL}" =~ ^[1-9]$ ]]; then
		echo "${_CLR_RED}  ✗${_CLR_RESET} Bzip compression level is not in a range between 1 and 9!"
		errors=1
	fi
	if ! [[ "${XZ_COMPRESSION_LEVEL}" =~ ^[1-9]$ ]]; then
		echo "${_CLR_RED}  ✗${_CLR_RESET} Xz compression level is not in a range between 1 and 9!"
		errors=1
	fi
	if ! [[ "${ZSTD_COMPRESSION_LEVEL}" =~ ^[1-9]+$ ]] || ! [ "${ZSTD_COMPRESSION_LEVEL}" -ge 1 -a "${ZSTD_COMPRESSION_LEVEL}" -le 19 ]; then
		echo "${_CLR_RED}  ✗${_CLR_RESET} Zstd compression level is not in a range between 1 and 19!"
		errors=1
	fi
	if [ "${USE_CCACHE}" != "NO" ] && [ "${USE_CCACHE}" != "YES" ]; then
		echo "${_CLR_RED}  ✗${_CLR_RESET} Use ccache variable is not set to either YES or NO"
		errors=1
	fi
	if [ "${USE_CCACHE}" != "NO" ]; then
		if [ "${USE_CCACHE_BIND}" != "NO" ] && [ "${USE_CCACHE_BIND}" != "YES" ]; then
			echo "${_CLR_RED}  ✗${_CLR_RESET} Ccache bind variable is not set to either YES or NO"
			errors=1
		fi
		if [ "${USE_CCACHE_FILE}" != "NO" ] && [ "${USE_CCACHE_FILE}" != "YES" ]; then
			echo "${_CLR_RED}  ✗${_CLR_RESET} Ccache file variable is not set to either YES or NO"
			errors=1
		fi
		if [ "${USE_CCACHE_BIND}" != "YES" ] && [ "${USE_CCACHE_FILE}" != "YES" ]; then
			echo "${_CLR_RED}  ✗${_CLR_RESET} If USE_CCACHE is set to YES, either USE_CCACHE_BIND or USE_CCACHE_FILE must be set to YES"
			errors=1
		elif [ "${USE_CCACHE_FILE}" == "YES" ] && [ "${USE_CCACHE_BIND}" == "YES" ]; then
			echo "${_CLR_RED}  ✗${_CLR_RESET} Only one of USE_CCACHE_FILE or USE_CCACHE_BIND can be set to YES"
			errors=1
		fi
		if [ -z "${CCACHE_DIR}" ]; then
			echo "${_CLR_RED}  ✗${_CLR_RESET} Ccache folder variable is empty or undefined!"
			errors=1
		elif ! validateSafePath "CCACHE_DIR" "${CCACHE_DIR}"; then
			errors=1
		fi
		if [ ! -d "${CCACHE_DIR}" ] && [ "${USE_CCACHE_BIND}" == "YES" ]; then
			echo "${_CLR_RED}  ✗${_CLR_RESET} Ccache folder ${CCACHE_DIR} does NOT exist"
			errors=1
		fi
	fi
	if [ "${USE_SCCACHE}" != "NO" ] && [ "${USE_SCCACHE}" != "YES" ]; then
		echo "${_CLR_RED}  ✗${_CLR_RESET} Use sccache variable is not set to either YES or NO"
		errors=1
	fi
	if [ "${USE_SCCACHE}" != "NO" ]; then
		if [ "${USE_SCCACHE_BIND}" != "NO" ] && [ "${USE_SCCACHE_BIND}" != "YES" ]; then
			echo "${_CLR_RED}  ✗${_CLR_RESET} Sccache bind variable is not set to either YES or NO"
			errors=1
		fi
		if [ "${USE_SCCACHE_FILE}" != "NO" ] && [ "${USE_SCCACHE_FILE}" != "YES" ]; then
			echo "${_CLR_RED}  ✗${_CLR_RESET} Sccache file variable is not set to either YES or NO"
			errors=1
		fi
		if [ "${USE_SCCACHE_BIND}" != "YES" ] && [ "${USE_SCCACHE_FILE}" != "YES" ]; then
			echo "${_CLR_RED}  ✗${_CLR_RESET} If USE_SCCACHE is set to YES, either USE_SCCACHE_BIND or USE_SCCACHE_FILE must be set to YES"
			errors=1
		elif [ "${USE_SCCACHE_FILE}" == "YES" ] && [ "${USE_SCCACHE_BIND}" == "YES" ]; then
			echo "${_CLR_RED}  ✗${_CLR_RESET} Only one of USE_SCCACHE_FILE or USE_SCCACHE_BIND can be set to YES"
			errors=1
		fi
		if [ -z "${SCCACHE_DIR}" ]; then
			echo "${_CLR_RED}  ✗${_CLR_RESET} Sccache folder variable is empty or undefined!"
			errors=1
		elif ! validateSafePath "SCCACHE_DIR" "${SCCACHE_DIR}"; then
			errors=1
		fi
		if [ ! -d "${SCCACHE_DIR}" ] && [ "${USE_SCCACHE_BIND}" == "YES" ]; then
			echo "${_CLR_RED}  ✗${_CLR_RESET} Sccache folder ${SCCACHE_DIR} does NOT exist"
			errors=1
		fi
	fi
	if [ "${USE_PKG_BIND}" != "NO" ] && [ "${USE_PKG_BIND}" != "YES" ]; then
		echo "${_CLR_RED}  ✗${_CLR_RESET} PKG dir bind variable is not set to either YES or NO"
		errors=1
	fi
	if [ -z "${PKG_DIR}" ]; then
		echo "${_CLR_RED}  ✗${_CLR_RESET} PKG folder variable is empty or undefined!"
		errors=1
	elif ! validateSafePath "PKG_DIR" "${PKG_DIR}"; then
		errors=1
	elif [ ! -d "${PKG_DIR}" ]; then
		echo "${_CLR_RED}  ✗${_CLR_RESET} PKG folder ${PKG_DIR} does NOT exist"
		errors=1
	fi
	if [ "${USE_DISTFILES_BIND}" != "NO" ] && [ "${USE_DISTFILES_BIND}" != "YES" ]; then
		echo "${_CLR_RED}  ✗${_CLR_RESET} Distfiles bind variable is not set to either YES or NO"
		errors=1
	fi
	if [ -z "${DISTFILES_DIR}" ]; then
		echo "${_CLR_RED}  ✗${_CLR_RESET} Distfiles folder variable is empty or undefined!"
		errors=1
	elif ! validateSafePath "DISTFILES_DIR" "${DISTFILES_DIR}"; then
		errors=1
	elif [ ! -d "${DISTFILES_DIR}" ]; then
		echo "${_CLR_RED}  ✗${_CLR_RESET} Distfiles folder ${DISTFILES_DIR} does NOT exist"
		errors=1
	fi
	if [ "${USE_REPOS_BIND}" != "NO" ] && [ "${USE_REPOS_BIND}" != "YES" ]; then
		echo "${_CLR_RED}  ✗${_CLR_RESET} Repos bind variable is not set to either YES or NO"
		errors=1
	fi
	if [ -z "${REPOS_DIR}" ]; then
		echo "${_CLR_RED}  ✗${_CLR_RESET} Repos folder variable is empty or undefined!"
		errors=1
	elif ! validateSafePath "REPOS_DIR" "${REPOS_DIR}"; then
		errors=1
	elif [ ! -d "${REPOS_DIR}" ]; then
		echo "${_CLR_RED}  ✗${_CLR_RESET} Repos folder ${REPOS_DIR} does NOT exist"
		errors=1
	fi
	if [ "${USE_GENTOO_PATCHES_BIND}" != "NO" ] && [ "${USE_GENTOO_PATCHES_BIND}" != "YES" ]; then
		echo "${_CLR_RED}  ✗${_CLR_RESET} Gentoo patches bind variable is not set to either YES or NO"
		errors=1
	fi
	if [ -z "${BTRFS_CHECKSUM}" ]; then
		BTRFS_CHECKSUM="crc32c"
		elif [ "${BTRFS_CHECKSUM}" != "crc32c" ] && [ "${BTRFS_CHECKSUM}" != "xxhash" ] && [ "${BTRFS_CHECKSUM}" != "sha256" ] && [ "${BTRFS_CHECKSUM}" != "blake2" ]; then
			echo "${_CLR_RED}  ✗${_CLR_RESET} BTRFS_CHECKSUM value ${BTRFS_CHECKSUM} is invalid, valid values are: crc32c, xxhash, sha256 and blake2"
			errors=1
	fi
	if [ -n "${EXTRA_BIND_MOUNT}" ]; then
		local protected_paths=("/" "/dev" "/sys" "/proc" "/run" "/tmp" "/etc" "/bin" "/sbin" "/lib" "/lib64" "/usr" "/boot" "/root")
		local saved_ifs="${IFS}"
		IFS=';' read -ra extra_mounts <<< "${EXTRA_BIND_MOUNT}"
		IFS="${saved_ifs}"
		for mount_path in "${extra_mounts[@]}"; do
			if [ -z "${mount_path}" ]; then
				continue
			fi
			if ! validateSafePath "EXTRA_BIND_MOUNT entry" "${mount_path}"; then
				errors=1
			else
				local protected
				for protected in "${protected_paths[@]}"; do
					if [ "${mount_path}" = "${protected}" ]; then
						echo "${_CLR_RED}  ✗${_CLR_RESET} EXTRA_BIND_MOUNT: ${mount_path} is a protected path and cannot be bind mounted into the chroot"
						errors=1
						break
					fi
				done
				if [ ! -d "${mount_path}" ]; then
					echo "${_CLR_RED}  ✗${_CLR_RESET} EXTRA_BIND_MOUNT: directory ${mount_path} does not exist on host"
					errors=1
				fi
			fi
		done
	fi
	if [ "${errors}" -eq 1 ]; then
		printf "\n${_CLR_BOLD_RED}  Configuration validation failed. Please fix the errors above.${_CLR_RESET}\n\n"
		exit 1
	fi
}

##
