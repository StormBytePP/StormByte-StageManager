function doChroot() {
	printf "\n  ${_CLR_BOLD_CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${_CLR_RESET}\n"
	printf "  ${_CLR_BOLD_WHITE}Entering chroot environment${_CLR_RESET}\n"
	printf "  ${_CLR_DIM}Don't forget to run: env-update && . /etc/profile${_CLR_RESET}\n"
	printf "  ${_CLR_BOLD_CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${_CLR_RESET}\n\n"
	if [ "${USE_SCCACHE}" == "YES" ]; then
		# Pass SCCACHE_DIR via env to avoid shell metacharacter injection from the config value
		chroot "${tmp_folder}" /usr/bin/env \
			"SCCACHE_DIR=${SCCACHE_DIR}" \
			SCCACHE_CACHE_SIZE=20G \
			SCCACHE_IDLE_TIMEOUT=0 \
			/bin/bash -c \
			'su - portage -s /bin/bash -c "SCCACHE_DIR=\"$SCCACHE_DIR\" SCCACHE_CACHE_SIZE=20G SCCACHE_IDLE_TIMEOUT=0 /usr/bin/sccache --start-server" 2>/dev/null || true; exec /bin/bash -i'
	else
		chroot "${tmp_folder}" /bin/bash -i
	fi
}

##
# @brief Stops the sccache server running inside the chroot (if any).
##
function stopSccacheServer() {
	if [ "${USE_SCCACHE}" == "YES" ]; then
		if [ -x "${tmp_folder}/usr/bin/sccache" ]; then
			handleCommand "chroot \"${tmp_folder}\" su - portage -s /bin/bash -c '/usr/bin/sccache --stop-server' || chroot \"${tmp_folder}\" /usr/bin/sccache --stop-server || true" "Stopping Sccache server"
		fi
	fi
}

##
# @brief Lists all tarball files in the configured folder.
##
function doList() {
	if [ -z "${file_list}" ]; then
		displayError "File list is empty, check ${TARBALL_FOLDER} contents!"
	fi
	printf "\n  ${_CLR_BOLD_CYAN}%-5s  %-10s  %s${_CLR_RESET}\n" "Index" "Size" "File Name"
	printf "  ${_CLR_DIM}─────  ──────────  ──────────────────────────────────────────${_CLR_RESET}\n"
	for i in "${!file_list[@]}"; do
		tarball_filename=`basename ${file_list[$i]}`
		local size=`ls -s --block-size=1048576 "${file_list[$i]}" | cut -d' ' -f1`
		local size_str="${size} MiB"
		local extra=""
		local row_open="" row_close=""
		if [ -f "${TARBALL_FOLDER}/${tarball_filename}.notes" ]; then
			extra+=" ${_CLR_BOLD_GREEN}[notes]${_CLR_RESET}"
		fi
		if [ -f "/tmp/.${tarball_filename}.lock" ]; then
			extra+=" ${_CLR_BOLD_YELLOW}[in use]${_CLR_RESET}"
			row_open="${_CLR_YELLOW}"
			row_close="${_CLR_RESET}"
		fi
		printf "  %s%-5s  %-10s  %s%s%s\n" "${row_open}" "$i" "${size_str}" "${tarball_filename}" "${row_close}" "${extra}"
	done
	printf "\n"
}

##
# @brief Creates a lockfile to prevent concurrent operations.
##
function doLock() {
	printStep "Setting lockfile"
	if ! (set -o noclobber; : > "${lockfile}") 2>/dev/null; then
		printFail
		printf "\n  ${_CLR_BOLD_RED}Another instance is already running.${_CLR_RESET}\n"
		printf "  Lockfile: ${_CLR_CYAN}%s${_CLR_RESET}\n" "${lockfile}"
		printf "  ${_CLR_DIM}If this is an error, manually delete the lockfile.${_CLR_RESET}\n\n"
		exit 1
	fi
	printOK
}

##
# @brief Removes the lockfile after operations are complete.
##
function doUnlock() {
	handleCommand "rm -f ${lockfile}" "Removing lockfile"
}

##
# @brief Configures and enters a chroot environment using a tarball.
#
# @param [optional] $1 The tarball file to use.
##
function doUse() {
	# If no parameter if received, it will autodetect from script arguments, otherwise it will use provided filename as parameter
	setAndCheckFile "$@"
	doLock
	createTMPFolder
	mountTEMP
	extractArchive
	mountPKG
	mountDistfiles
	mountRepos
	mountGentooPatches
	mountExtraBindMounts
	prepareCache
	unpackCache
	mountSystem
	doChroot
	unmountSystem
	unprepareCache
	unmountExtraBindMounts
	unmountGentooPatches
	unmountRepos
	unmountDistfiles
	unmountPKG
	cleanStage
	saveChanges
	unmountTEMP
	deleteTMPFolder
	doUnlock
}

##
# @brief Converts a tarball to a different compression format.
##
function doConvert() {
	setAndCheckFile
	setCompression ${parameters[2]}
	setDecompression ${tarball_extension}
	doLock
	createTMPFolder
	mountTEMP
	extractArchive
	readonlyTEMP
	compressArchive
	unmountTEMP
	deleteTMPFolder
	doUnlock
}

##
# @brief Exports a tarball to a specified folder with a new compression format.
##
function doExport() {
	setOutputFolder "${parameters[2]}"
	setAndCheckFile
	setCompression ${parameters[3]}
	setDecompression ${tarball_extension}
	tarball_output="${tarball_output%.*}-`date +%Y%m%d`.${tarball_output##*.}"
	if [ -f "${output_folder}/${tarball_output}" ]; then
		local reply=""
		while [[ ! $reply =~ ^[YyNn]$ ]]; do
			printf "  ${_CLR_BOLD_YELLOW}File ${_CLR_BOLD_WHITE}%s${_CLR_RESET}${_CLR_BOLD_YELLOW} already exists. Overwrite?${_CLR_RESET} [${_CLR_BOLD_GREEN}Y${_CLR_RESET}/${_CLR_BOLD_RED}N${_CLR_RESET}]: " "${tarball_output}"
			read -r
			reply=$REPLY
		done
		if [[ $reply =~ ^[Nn]$ ]]; then
			printf "  ${_CLR_DIM}No action was taken.${_CLR_RESET}\n"
			exit 1
		fi
	fi
	doLock
	createTMPFolder
	mountTEMP
	extractArchive
	readonlyTEMP
	compressArchive
	unmountTEMP
	deleteTMPFolder
	doUnlock
}

##
# @brief Deletes a tarball file.
##
function doDelete() {
	setAndCheckFile
	local reply=""
	while [[ ! $reply =~ ^[YyNn]$ ]]; do
		printf "  ${_CLR_BOLD_YELLOW}Delete ${_CLR_BOLD_WHITE}%s${_CLR_RESET}${_CLR_BOLD_YELLOW}?${_CLR_RESET} [${_CLR_BOLD_GREEN}Y${_CLR_RESET}/${_CLR_BOLD_RED}N${_CLR_RESET}]: " "${tarball}"
		read -r
		reply=$REPLY
	done
	if [[ $reply =~ ^[Nn]$ ]]; then
		printf "  ${_CLR_DIM}No action was taken.${_CLR_RESET}\n"
		exit 0
	fi
	doLock
	handleCommand "rm -f ${tarball_filename_fullpath}" "Deleting file ${tarball}"
	doUnlock
}

##
# @brief Renames a tarball file.
##
function doRename() {
	local new_filename=`basename "${parameters[2]}"`
	setAndCheckFile
	checkFileCopy "${tarball_filename_fullpath}" "${new_filename}"
	doLock
	handleCommand "mv '${tarball_filename_fullpath}' '${TARBALL_FOLDER}/${new_filename}'" "Renaming ${tarball} to ${new_filename}"
	doUnlock
}

##
# @brief Rebases a tarball with a new file name and compression format.
##
function doRebase() {
	# doRebase is a special version of do use, but changing the compression method and output file right before save changes, so when saving, new filename and compression method will be used instead
	setAndCheckFile
	doLock
	createTMPFolder
	mountTEMP
	extractArchive "${TARBALL_FOLDER}/${parameters[2]}"
	mountPKG
	mountDistfiles
	mountRepos
	mountGentooPatches
	mountExtraBindMounts
	prepareCache
	unpackCache
	mountSystem
	doChroot
	unmountSystem
	unprepareCache
	unmountExtraBindMounts
	unmountGentooPatches
	unmountRepos
	unmountDistfiles
	unmountPKG
	cleanStage
	saveChanges "${TARBALL_FOLDER}/${parameters[2]}"
	unmountTEMP
	deleteTMPFolder
	doUnlock
}

##
# @brief Validates the parameters for downloading a Gentoo stage tarball.
##
function checkDownloadParameters() {
	arch="${parameters[1]}"
	profile="${parameters[2]}"
	profile_error=0
	arch_error=0
	if [ -z "${profile}" ]; then
		profile="default"
	fi
	case "${arch}" in
		i486)
			stage_base_url="${gentoo_base_url}/x86/autobuilds"
			case "${profile}" in
				default)
					stage_info_file="latest-stage3-i486-openrc.txt"
					;;
				*)
					profile_error=1
					;;
			esac
			;;
		i686)
			stage_base_url="${gentoo_base_url}/x86/autobuilds"
			case "${profile}" in
				default)
					stage_info_file="latest-stage3-i686-openrc.txt"
					;;
				hardened)
					stage_info_file="latest-stage3-i686-hardened-openrc.txt"
					;;
				systemd)
					stage_info_file="latest-stage3-i686-systemd.txt"
					;;
				uclibc-hardened)
					stage_info_file="latest-stage3-i686-uclibc-hardened.txt"
					;;
				uclibc-vanilla)
					stage_info_file="latest-stage3-i686-uclibc-vanilla.txt"
					;;
				*)
					profile_error=1
					;;
			esac
			;;
		amd64)
			stage_base_url="${gentoo_base_url}/amd64/autobuilds"
			case "${profile}" in
				default)
					stage_info_file="latest-stage3-amd64-openrc.txt"
					;;
				hardened)
					stage_info_file="latest-stage3-amd64-hardened-openrc.txt"
					;;
				nomultilib)
					stage_info_file="latest-stage3-amd64-nomultilib-openrc.txt"
					;;
				systemd)
					stage_info_file="latest-stage3-amd64-systemd.txt"
					;;
				hardened+nomultilib)
					stage_info_file="latest-stage3-amd64-hardened-nomultilib-openrc.txt"
					;;
				hardened-selinux)
					stage_info_file="latest-stage3-amd64-hardened-selinux-openrc.txt"
					;;
				hardened-selinux+nomultilib)
					stage_info_file="latest-stage3-amd64-hardened-nomultilib-selinux-openrc.txt"
					;;
				uclibc-hardened)
					stage_info_file="latest-stage3-amd64-uclibc-hardened.txt"
					;;
				uclibc-vanilla)
					stage_info_file="latest-stage3-amd64-uclibc-vanilla.txt"
					;;
				*)
					profile_error=1
					;;
			esac
			;;
		x32)
			stage_base_url="${gentoo_base_url}/x86/autobuilds"
			case "${profile}" in
				default)
					stage_info_file="latest-stage3-x32.txt"
					;;
				*)
					profile_error=1
					;;
			esac
			;;
		*)
			arch_error=1
			;;
	esac

	if [ "${arch_error}" -eq 1 ]; then
		displayError "Arch '${arch}' is not available for download, consult $self help download"
	fi
	if [ "${profile_error}" -eq 1 ]; then
		displayError "Profile '${profile}' is not available for arch '${arch}', consult $self help download"
	fi
}

##
# @brief Downloads a Gentoo stage tarball based on the specified architecture and profile.
##
function doDownload() {
	arch="${parameters[1]}"
	profile="${parameters[2]}"
	if [ -z "${profile}" ]; then
		profile="default"
	fi

	checkDownloadParameters
	createTMPFolder
	handleCommand "curl --fail -o ${tmp_folder}/${stage_info_file} ${stage_base_url}/${stage_info_file}" "Downloading stage information"
	if [ ! -s "${tmp_folder}/${stage_info_file}" ]; then
		displayError "Failed to download or empty stage info file: ${stage_info_file}"
	fi
	stage_file="`grep -m1 '^[^#].*\.tar\.xz' \"${tmp_folder}/${stage_info_file}\" | awk '{print $1}'`"
	if [ -z "${stage_file}" ]; then
		displayError "Could not parse stage file path from info file: ${stage_info_file}"
	fi
	# Validate the stage file path to prevent injection from a compromised server response
	if [[ ! "${stage_file}" =~ ^[a-zA-Z0-9/_.-]+\.tar\.xz$ ]]; then
		displayError "Stage file path from info file contains unexpected characters: ${stage_file}"
	fi
	local stage_basename
	stage_basename="$(basename "${stage_file}")"
	handleCommand "curl --fail -o ${tmp_folder}/${stage_basename} ${stage_base_url}/${stage_file}" "Downloading ${stage_basename}"
	# Best-effort integrity verification via DIGESTS file
	printStep "Downloading integrity data for ${stage_basename}"
	if curl --fail --silent -o "${tmp_folder}/${stage_basename}.DIGESTS" \
	        "${stage_base_url}/${stage_file}.DIGESTS" 2>/dev/null; then
		printOK
		printStep "Verifying integrity of ${stage_basename}"
		# Match SHA512 (128 hex chars) or SHA256 (64 hex chars) line for the tarball
		local hash_line
		hash_line="$(grep -E "^[0-9a-fA-F]{128}[[:space:]]+${stage_basename}$" \
		    "${tmp_folder}/${stage_basename}.DIGESTS" 2>/dev/null | head -1)"
		if [ -z "${hash_line}" ]; then
			hash_line="$(grep -E "^[0-9a-fA-F]{64}[[:space:]]+${stage_basename}$" \
			    "${tmp_folder}/${stage_basename}.DIGESTS" 2>/dev/null | head -1)"
		fi
		if [ -n "${hash_line}" ]; then
			local hash_algo
			if [[ "${hash_line}" =~ ^[0-9a-fA-F]{128}[[:space:]] ]]; then
				hash_algo="sha512sum"
			else
				hash_algo="sha256sum"
			fi
			if ( cd "${tmp_folder}" && echo "${hash_line}" | ${hash_algo} -c --status 2>/dev/null ); then
				printOK
			else
				printFail
				rm -f "${tmp_folder}/${stage_basename}" "${tmp_folder}/${stage_basename}.DIGESTS"
				deleteTMPFolder
				displayError "Integrity check failed for ${stage_basename}"
			fi
		else
			printSkip "could not extract hash from DIGESTS file"
		fi
		rm -f "${tmp_folder}/${stage_basename}.DIGESTS"
	else
		printSkip "DIGESTS file not available on this mirror"
	fi
	handleCommand "mv '${tmp_folder}/${stage_basename}' '${TARBALL_FOLDER}/${stage_basename}'" "Moving stage data from temporary folder"
	deleteTMPFolder
	printf "\n  ${_CLR_BOLD_GREEN}✓${_CLR_RESET} ${_CLR_BOLD_WHITE}%s${_CLR_RESET} downloaded to ${_CLR_CYAN}%s${_CLR_RESET}\n\n" "${stage_basename}" "${TARBALL_FOLDER}"
}

##
# @brief Displays help information for a specific command or general usage.
##
function doHelp() {
	case "${parameters[1]}" in
		list)
			helpList
			;;
		use)
			helpUse
			;;
		convert)
			helpConvert
			;;
		export)
			helpExport
			;;
		delete)
			helpDelete
			;;
		rename)
			helpRename
			;;
		rebase)
			helpRebase
			;;
		download)
			helpDownload
			;;
		compression)
			helpCompression
			;;
		notes)
			helpNotes
			;;
		*)
			usage
			;;
	esac
}

##
# @brief Manages notes for a tarball (edit or delete).
##
function doNotes() {
	setAndCheckFile
	case "${parameters[2]}" in
		delete)
			handleCommand "rm -f '${tarball_filename_fullpath}.notes'" "Deleting notes for ${tarball}"
			;;
		edit)
			printf "  ${_CLR_CYAN}▸${_CLR_RESET} Editing notes for ${_CLR_BOLD_WHITE}%s${_CLR_RESET}\n" "$(basename ${tarball_filename_fullpath})"
			if [ "${DETACH_NOTE_EDITOR}" == "YES" ]; then
				"${TARBALL_NOTE_EDITOR}" "${tarball_filename_fullpath}.notes" > /dev/null 2>&1 &
			else
				"${TARBALL_NOTE_EDITOR}" "${tarball_filename_fullpath}.notes"
			fi
			
			;;
		*)
			displayError "Unrecognized notes subcommand"
			helpNotes
	esac
}
	

##
# @brief Initializes the script and executes the specified command.
##
function doInit() {
	header
	checkVars
	setOutputFolder

	case $command in
		list)
			doList
			;;
		use)
			doUse
			;;
		convert)
			doConvert
			;;
		export)
			doExport
			;;
		delete)
			doDelete
			;;
		rename)
			doRename
			;;
		rebase)
			doRebase
			;;
		download)
			doDownload
			;;
		help)
			doHelp
			;;
		notes)
			doNotes
			;;
		*)
			usage
			exit 1
	esac
	exit 0
}

# Start the script
doInit